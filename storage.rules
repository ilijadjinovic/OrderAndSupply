rules_version = '2';

// ============================================================================
// STORAGE RULES — prilozi (fiskalni računi, fotografije robe/isporuke)
// Putanja: companies/{companyId}/orders/{orderId}/{fileName}
// ============================================================================
service firebase.storage {
  match /b/{bucket}/o {
    match /companies/{companyId}/orders/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
